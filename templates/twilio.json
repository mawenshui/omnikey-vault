    { "key": "api_key_secret", "label": "API Key Secret", "kind": "secret", "sensitive": true, "required": false, "default_mask": "••••••••••••••••••••••••••••••••••••", "validation": { "regex": "^[A-Za-z0-9]{32}$", "hint": "32 字符" }, "rotatable": true, "group": "secondary", "description": "API Key Secret" }
