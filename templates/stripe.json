{
  "id": "stripe",
  "platform_id": "stripe",
  "name": "Stripe",
  "category": "payment",
  "icon": "stripe",
  "official_docs_url": "https://docs.stripe.com/keys",
  "auth_header": "Authorization: Bearer <secret_key>",
  "default_base_url": "https://api.stripe.com/v1",
  "mvp_included": true,
  "introduced_in": "v0.1",
"region": "international",
  "expires_at_supported": false,
  "rotation_supported": true,
  "rotation_provider": "stripe",
  "notes": "Use restricted keys (rk_) over secret keys (sk_) for least privilege. Publishable keys are public.",
  "fields": [
    {
      "key": "secret_key",
      "label": "Secret Key",
      "kind": "secret",
      "sensitive": true,
      "required": false,
      "default_mask": "sk_live_\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022",
      "placeholder": "sk_live_...",
      "validation": { "regex": "^sk_(live|test)_[A-Za-z0-9]{24,}$", "hint": "Secret key: sk_live_ or sk_test_ + 24+ chars" },
      "rotatable": true,
      "expires_at_supported": false,
      "group": "primary",
      "description": "Full-access secret key (sk_live_ for production, sk_test_ for test)."
    },
    {
      "key": "restricted_key",
      "label": "Restricted Key",
      "kind": "secret",
      "sensitive": true,
      "required": false,
      "default_mask": "rk_\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022",
      "placeholder": "rk_live_...",
      "validation": { "regex": "^rk_(live|test)_[A-Za-z0-9]{24,}$", "hint": "Restricted key: rk_live_ or rk_test_ + 24+ chars" },
      "rotatable": true,
      "expires_at_supported": false,
      "group": "primary",
      "description": "Restricted key (rk_) with limited permissions. Recommended over sk_."
    },
    {
      "key": "publishable_key",
      "label": "Publishable Key",
      "kind": "text",
      "sensitive": false,
      "required": false,
      "default_mask": "pk_live_\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022",
      "placeholder": "pk_live_...",
      "validation": { "regex": "^pk_(live|test)_[A-Za-z0-9]{24,}$", "hint": "Publishable key: pk_live_ or pk_test_ + 24+ chars" },
      "rotatable": false,
      "expires_at_supported": false,
      "group": "secondary",
      "description": "Publishable key (pk_). Public, used client-side."
    },
    {
      "key": "webhook_secret",
      "label": "Webhook Signing Secret",
      "kind": "secret",
      "sensitive": true,
      "required": false,
      "default_mask": "whsec_\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022",
      "placeholder": "whsec_...",
      "validation": { "regex": "^whsec_[A-Za-z0-9]{24,}$", "hint": "Webhook signing secret (whsec_)" },
      "rotatable": true,
      "expires_at_supported": false,
      "group": "secondary",
      "description": "Webhook signing secret for Stripe webhook signature verification."
    },
    {
      "key": "account_id",
      "label": "Account ID",
      "kind": "text",
      "sensitive": false,
      "required": false,
      "placeholder": "acct_...",
      "validation": { "regex": "^acct_[A-Za-z0-9]{16,}$", "hint": "Connected account ID (acct_ prefix)" },
      "rotatable": false,
      "expires_at_supported": false,
      "group": "secondary",
      "description": "Stripe account ID (acct_)."
    }
  ]
}
