{
  "id": "openai",
  "platform_id": "openai",
  "name": "OpenAI",
  "category": "ai_llm",
  "icon": "openai",
  "official_docs_url": "https://platform.openai.com/docs/api-reference/introduction",
  "auth_header": "Authorization: Bearer <api_key>",
  "default_base_url": "https://api.openai.com/v1",
  "mvp_included": true,
  "introduced_in": "v0.1",
"region": "international",
  "expires_at_supported": false,
  "rotation_supported": true,
  "rotation_provider": "openai",
  "notes": "Project-scoped keys (sk-proj-) are recommended over legacy user-scoped keys (sk-).",
  "fields": [
    {
      "key": "api_key",
      "label": "API Key (Project-Scoped)",
      "kind": "secret",
      "sensitive": true,
      "required": false,
      "default_mask": "sk-proj-\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022",
      "placeholder": "sk-proj-...",
      "validation": { "regex": "^sk-proj-[A-Za-z0-9_-]{20,}$", "hint": "Project-scoped key: sk-proj- + 20+ chars (2024+)" },
      "rotatable": true,
      "expires_at_supported": false,
      "group": "primary",
      "description": "Project-scoped API key (sk-proj-). Recommended for new keys."
    },
    {
      "key": "api_key_legacy",
      "label": "API Key (Legacy)",
      "kind": "secret",
      "sensitive": true,
      "required": false,
      "default_mask": "sk-\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022",
      "placeholder": "sk-...",
      "validation": { "regex": "^sk-[A-Za-z0-9]{40,}$", "hint": "Legacy user-scoped key: sk- + 40 chars" },
      "rotatable": true,
      "expires_at_supported": false,
      "group": "primary",
      "description": "Legacy user-scoped API key (sk- + 40 chars). Being deprecated."
    },
    {
      "key": "admin_api_key",
      "label": "Admin API Key",
      "kind": "secret",
      "sensitive": true,
      "required": false,
      "default_mask": "sk-admin-\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022",
      "placeholder": "sk-admin-...",
      "validation": { "regex": "^sk-admin-[A-Za-z0-9_-]+$", "hint": "Admin API key: sk-admin- prefix" },
      "rotatable": true,
      "expires_at_supported": false,
      "group": "advanced",
      "description": "Admin API key for organization management."
    },
    {
      "key": "organization_id",
      "label": "Organization ID",
      "kind": "text",
      "sensitive": false,
      "required": false,
      "placeholder": "org-...",
      "validation": { "regex": "^org-[A-Za-z0-9]{6,}$", "hint": "Organization ID (org- prefix)" },
      "rotatable": false,
      "expires_at_supported": false,
      "group": "secondary",
      "description": "Organization ID (org-). Required for multi-org accounts."
    },
    {
      "key": "project_id",
      "label": "Project ID",
      "kind": "text",
      "sensitive": false,
      "required": false,
      "placeholder": "proj_...",
      "validation": { "regex": "^proj_[A-Za-z0-9]+$", "hint": "Project ID (proj_ prefix)" },
      "rotatable": false,
      "expires_at_supported": false,
      "group": "secondary",
      "description": "Project ID (proj_). Used with project-scoped keys."
    }
  ]
}
