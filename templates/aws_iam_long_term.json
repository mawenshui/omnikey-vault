{
  "id": "aws_iam_long_term",
  "platform_id": "aws",
  "name": "AWS IAM (Long-Term Credentials)",
  "category": "cloud",
  "icon": "aws",
  "official_docs_url": "https://docs.aws.amazon.com/IAM/latest/UserGuide/security-creds.html",
  "auth_header": "Authorization: AWS4-HMAC-SHA256 ...",
  "default_base_url": "https://sts.amazonaws.com",
  "mvp_included": true,
  "introduced_in": "v0.1",
  "expires_at_supported": false,
  "rotation_supported": false,
  "notes": "Long-term IAM access keys. For temporary credentials, use aws_sts_temporary (v0.2). Rotate via IAM console.",
  "fields": [
    {
      "key": "access_key_id",
      "label": "Access Key ID",
      "kind": "text",
      "sensitive": false,
      "required": true,
      "default_mask": "AKIA\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022",
      "placeholder": "AKIAIOSFODNN7EXAMPLE",
      "validation": { "regex": "^AKIA[A-Z0-9]{16}$", "hint": "20 chars: AKIA + 16 uppercase alphanumeric" },
      "rotatable": false,
      "expires_at_supported": false,
      "group": "primary",
      "description": "IAM Access Key ID (20 chars, AKIA prefix)."
    },
    {
      "key": "secret_access_key",
      "label": "Secret Access Key",
      "kind": "secret",
      "sensitive": true,
      "required": true,
      "default_mask": "\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022",
      "placeholder": "wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY",
      "validation": { "regex": "^[A-Za-z0-9/+=]{40}$", "hint": "40 chars base64-style" },
      "rotatable": true,
      "expires_at_supported": false,
      "group": "primary",
      "description": "IAM Secret Access Key (40 chars)."
    },
    {
      "key": "account_id",
      "label": "Account ID",
      "kind": "text",
      "sensitive": false,
      "required": false,
      "placeholder": "123456789012",
      "validation": { "regex": "^\\d{12}$", "hint": "12-digit AWS account ID" },
      "rotatable": false,
      "expires_at_supported": false,
      "group": "secondary",
      "description": "12-digit AWS account ID."
    },
    {
      "key": "region",
      "label": "Default Region",
      "kind": "text",
      "sensitive": false,
      "required": false,
      "placeholder": "us-east-1",
      "validation": { "regex": "^[a-z]{2}-[a-z]+-\\d+$", "hint": "Region code (e.g. us-east-1, ap-northeast-1)" },
      "rotatable": false,
      "expires_at_supported": false,
      "group": "secondary",
      "description": "Default AWS region for API calls."
    },
    {
      "key": "arn",
      "label": "IAM User ARN",
      "kind": "text",
      "sensitive": false,
      "required": false,
      "placeholder": "arn:aws:iam::123456789012:user/username",
      "validation": { "regex": "^arn:aws:iam::\\d{12}:user/[A-Za-z0-9_+=,.@-]+$", "hint": "IAM user ARN" },
      "rotatable": false,
      "expires_at_supported": false,
      "group": "advanced",
      "description": "IAM user ARN (for audit / identification)."
    },
    {
      "key": "iam_user_name",
      "label": "IAM User Name",
      "kind": "text",
      "sensitive": false,
      "required": false,
      "placeholder": "admin",
      "rotatable": false,
      "expires_at_supported": false,
      "group": "secondary",
      "description": "IAM user name associated with this access key."
    }
  ]
}
