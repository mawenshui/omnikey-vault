{
  "id": "aliyun_oss",
  "platform_id": "aliyun_oss",
  "name": "阿里云 OSS (对象存储)",
  "category": "cloud",
  "icon": "aliyun",
  "official_docs_url": "https://help.aliyun.com/zh/oss/developer-category/",
  "auth_header": "Authorization: OSS4-HMAC-SHA256 ...",
  "default_base_url": "https://oss-cn-hangzhou.aliyuncs.com",
  "mvp_included": false,
  "introduced_in": "v1.7",
  "expires_at_supported": false,
  "rotation_supported": true,
  "rotation_provider": "aliyun",
  "notes": "阿里云 OSS 使用 RAM AccessKey 认证。推荐使用 STS 临时凭证或 RAM 子账号最小权限策略。",
  "fields": [
    {
      "key": "access_key_id",
      "label": "AccessKey ID",
      "kind": "text",
      "sensitive": false,
      "required": true,
      "default_mask": "LTAI••••••••",
      "placeholder": "LTAIxxxxxxxxxxxxxxxxxx",
      "validation": { "regex": "^LTAI[A-Za-z0-9]{16}$", "hint": "以 LTAI 开头，20 字符" },
      "group": "primary"
    },
    {
      "key": "access_key_secret",
      "label": "AccessKey Secret",
      "kind": "secret",
      "sensitive": true,
      "required": true,
      "default_mask": "••••••••••••••••••••••••••••••••",
      "validation": { "regex": "^[A-Za-z0-9]{30}$", "hint": "30 字符" },
      "rotatable": true,
      "expires_at_supported": false,
      "group": "primary"
    },
    {
      "key": "bucket_name",
      "label": "Bucket 名称",
      "kind": "text",
      "sensitive": false,
      "required": false,
      "placeholder": "my-bucket",
      "group": "primary"
    },
    {
      "key": "endpoint",
      "label": "Endpoint",
      "kind": "url",
      "sensitive": false,
      "required": false,
      "placeholder": "https://oss-cn-hangzhou.aliyuncs.com",
      "group": "primary"
    },
    {
      "key": "region_id",
      "label": "地域 ID",
      "kind": "text",
      "sensitive": false,
      "required": false,
      "placeholder": "cn-hangzhou",
      "validation": { "regex": "^cn-[a-z]+(-[0-9]+)?$", "hint": "如 cn-hangzhou, cn-shanghai, cn-beijing" },
      "group": "secondary"
    }
  ]
}
