<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OmniKeyVault.Cli.Gui.Views.AuditLogWindow"
        Title="审计日志"
        Width="800" Height="560"
        MinWidth="600" MinHeight="400"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgCardBrush}">
    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Header -->
        <Border Grid.Row="0" Padding="16,12" Background="{DynamicResource BgElevatedBrush}" CornerRadius="8,8,0,0">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0">
                    <TextBlock Text="📋 审计日志" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource FgBrush}" />
                    <TextBlock x:Name="SummaryText" Text="加载中..." FontSize="11"
                               Foreground="{DynamicResource FgMutedBrush}" Margin="0,4,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button x:Name="ExportBtn" Classes="ghost" Content="导出 CSV" Click="OnExportClick" Padding="12,6" />
                    <Button x:Name="ClearBtn" Classes="ghost" Content="清空" Click="OnClearClick" Padding="12,6" />
                    <Button x:Name="RefreshBtn" Classes="primary" Content="刷新" Click="OnRefreshClick" Padding="12,6" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Log list -->
        <Border Grid.Row="1" Padding="0" Background="{DynamicResource BgBrush}">
            <ScrollViewer x:Name="LogScroll" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="LogList" Margin="8" Spacing="2" />
            </ScrollViewer>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="2" Padding="12,8" Background="{DynamicResource BgElevatedBrush}" CornerRadius="0,0,8,8">
            <TextBlock x:Name="FooterText" Text="审计日志记录所有关键操作 · 不含敏感数据"
                       FontSize="11" Foreground="{DynamicResource FgFaintBrush}"
                       HorizontalAlignment="Center" />
        </Border>
    </Grid>
</Window>
