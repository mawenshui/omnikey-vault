<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OmniKeyVault.Cli.Gui.Views.VaultSwitcherWindow"
        Title="切换保险箱"
        Width="520" Height="480"
        MinWidth="400" MinHeight="360"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgCardBrush}">
    <Grid RowDefinitions="Auto,*,Auto">
        <Border Grid.Row="0" Padding="16,12" Background="{DynamicResource BgElevatedBrush}" CornerRadius="8,8,0,0">
            <TextBlock Text="🗂 切换保险箱" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource FgBrush}" />
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="VaultList" Margin="8" Spacing="4" />
        </ScrollViewer>

        <Border Grid.Row="2" Padding="12,8" Background="{DynamicResource BgElevatedBrush}" CornerRadius="0,0,8,8">
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <Button Classes="ghost" Content="打开其他..." Click="OnBrowseClick" Padding="12,6" />
                <Button Classes="ghost" Content="新建保险箱" Click="OnCreateClick" Padding="12,6" />
                <Button Classes="primary" Content="关闭" Click="OnCloseClick" Padding="12,6" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
