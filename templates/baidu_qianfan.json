      "expires_at_supported": false,
      "group": "primary",
      "description": "千帆应用 API Key。"
    },
    {
      "key": "secret_key",
      "label": "Secret Key",
      "kind": "secret",
      "sensitive": true,
      "required": true,
      "default_mask": "••••••••••••••••••••••••",
      "placeholder": "xxxxxxxxxxxxxxxx",
      "validation": { "regex": "^[A-Za-z0-9]{16,32}$", "hint": "16-32 字符" },
      "rotatable": true,
      "expires_at_supported": false,
      "group": "primary",
      "description": "千帆应用 Secret Key，用于换取 access_token。"
    },
    {
      "key": "app_id",
      "label": "AppID",
      "kind": "text",
      "sensitive": false,
      "required": false,
      "placeholder": "12345678",
      "validation": { "regex": "^\\d{8,12}$", "hint": "8-12 位数字" },
      "group": "secondary",
      "description": "千帆应用 ID。"
    }
