{
  "id": "supabase",
  "platform_id": "supabase",
  "name": "Supabase",
  "category": "database_auth",
  "icon": "supabase",
  "official_docs_url": "https://supabase.com/docs/guides/api/api-keys",
  "auth_header": "apikey: <secret_key>",
  "default_base_url": "https://<project_ref>.supabase.co",
  "mvp_included": true,
  "introduced_in": "v0.1",
  "expires_at_supported": false,
  "rotation_supported": true,
  "rotation_provider": "supabase",
  "notes": "New sb_secret_/sb_publishable_ keys (2025+) replace legacy JWT anon/service_role keys. Both are supported.",
  "fields": [
    {
      "key": "project_url",
      "label": "Project URL",
      "kind": "url",
      "sensitive": false,
      "required": true,
      "placeholder": "https://xyzcompany.supabase.co",
      "validation": { "regex": "^https://[a-z0-9-]+\\.supabase\\.co$", "hint": "Project URL (https://<ref>.supabase.co)" },
      "rotatable": false,
      "expires_at_supported": false,
      "group": "primary",
      "description": "Project URL (https://<project_ref>.supabase.co)."
    },
    {
      "key": "secret_key",
      "label": "Secret Key",
      "kind": "secret",
      "sensitive": true,
      "required": false,
      "default_mask": "sb_secret_\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022",
      "placeholder": "sb_secret_...",
      "validation": { "regex": "^sb_secret_[A-Za-z0-9_-]{40,}$", "hint": "New-format secret key: sb_secret_ + 40+ chars (2025+)" },
      "rotatable": true,
      "expires_at_supported": false,
      "group": "primary",
      "description": "Server-side secret key (sb_secret_). Never expose client-side."
    },
    {
      "key": "publishable_key",
      "label": "Publishable Key",
      "kind": "text",
      "sensitive": false,
      "required": false,
      "default_mask": "sb_publishable_\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022",
      "placeholder": "sb_publishable_...",
      "validation": { "regex": "^sb_publishable_[A-Za-z0-9_-]{40,}$", "hint": "New-format publishable key: sb_publishable_ + 40+ chars (2025+)" },
      "rotatable": false,
      "expires_at_supported": false,
      "group": "primary",
      "description": "Client-side publishable key (sb_publishable_)."
    },
    {
      "key": "service_role_key_legacy",
      "label": "Service Role Key (Legacy JWT)",
      "kind": "secret",
      "sensitive": true,
      "required": false,
      "default_mask": "eyJ\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022",
      "placeholder": "eyJhbGci...",
      "validation": { "regex": "^eyJ[A-Za-z0-9_-]+\\.eyJ[A-Za-z0-9_-]+\\.[A-Za-z0-9_-]+$", "hint": "Legacy JWT service role key" },
      "rotatable": true,
      "expires_at_supported": false,
      "group": "advanced",
      "description": "Legacy JWT service_role key (full bypass of RLS). Migrate to sb_secret_ when possible."
    },
    {
      "key": "anon_key_legacy",
      "label": "Anon Key (Legacy JWT)",
      "kind": "text",
      "sensitive": false,
      "required": false,
      "default_mask": "eyJ\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022",
      "placeholder": "eyJhbGci...",
      "validation": { "regex": "^eyJ[A-Za-z0-9_-]+\\.eyJ[A-Za-z0-9_-]+\\.[A-Za-z0-9_-]+$", "hint": "Legacy JWT anon key" },
      "rotatable": false,
      "expires_at_supported": false,
      "group": "advanced",
      "description": "Legacy JWT anon key (public, client-side). Migrate to sb_publishable_ when possible."
    },
    {
      "key": "database_url",
      "label": "Database URL (Direct)",
      "kind": "url",
      "sensitive": true,
      "required": false,
      "placeholder": "postgresql://postgres:[PASSWORD]@db.[ref].supabase.co:5432/postgres",
      "rotatable": false,
      "expires_at_supported": false,
      "group": "advanced",
      "description": "Direct Postgres connection URL."
    },
    {
      "key": "personal_access_token",
      "label": "Personal Access Token (Management API)",
      "kind": "secret",
      "sensitive": true,
      "required": false,
      "default_mask": "sbp_\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022",
      "placeholder": "sbp_...",
      "validation": { "regex": "^sbp_[a-f0-9]{40}$", "hint": "PAT: sbp_ + 40 hex chars" },
      "rotatable": true,
      "expires_at_supported": true,
      "group": "secondary",
      "description": "Personal Access Token for Supabase Management API (sbp_ + 40 hex)."
    },
    {
      "key": "jwt_secret",
      "label": "JWT Secret",
      "kind": "secret",
      "sensitive": true,
      "required": false,
      "default_mask": "\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022",
      "rotatable": true,
      "expires_at_supported": false,
      "group": "advanced",
      "description": "Project JWT secret (used to sign/verify legacy anon/service_role keys)."
    }
  ]
}
