{
  "id": "github",
  "platform_id": "github",
  "name": "GitHub",
  "category": "code_hosting",
  "icon": "github",
  "official_docs_url": "https://docs.github.com/en/authentication/keeping-your-account-and-data-secure/managing-your-personal-access-tokens",
  "auth_header": "Authorization: Bearer <pat>",
  "default_base_url": "https://api.github.com",
  "mvp_included": true,
  "introduced_in": "v0.1",
"region": "international",
  "expires_at_supported": true,
  "rotation_supported": true,
  "rotation_provider": "github",
  "notes": "Fine-grained PAT (2025-03 GA) is the recommended replacement for classic PAT. Classic PAT may be disabled by org policy.",
  "fields": [
    {
      "key": "pat_fine_grained",
      "label": "Fine-grained Personal Access Token",
      "kind": "secret",
      "sensitive": true,
      "required": false,
      "default_mask": "github_pat_\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022",
      "placeholder": "github_pat_82chars...",
      "validation": { "regex": "^github_pat_[A-Za-z0-9_]{82}$", "hint": "Fine-grained PAT: github_pat_ + 82 chars (2025+ recommended)" },
      "rotatable": true,
      "expires_at_supported": true,
      "group": "primary",
      "description": "Fine-grained PAT (2025-03-18 GA). Recommended over classic PAT."
    },
    {
      "key": "pat_classic",
      "label": "Classic Personal Access Token",
      "kind": "secret",
      "sensitive": true,
      "required": false,
      "default_mask": "ghp_\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022",
      "placeholder": "ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
      "validation": { "regex": "^ghp_[A-Za-z0-9]{36}$", "hint": "Classic PAT: ghp_ + 36 chars (legacy)" },
      "rotatable": true,
      "expires_at_supported": true,
      "group": "primary",
      "description": "Classic PAT (ghp_ + 36 chars). May be disabled by org policy."
    },
    {
      "key": "username",
      "label": "Username",
      "kind": "text",
      "sensitive": false,
      "required": false,
      "placeholder": "octocat",
      "group": "primary",
      "description": "GitHub username (for basic-auth API calls)."
    },
    {
      "key": "webhook_secret",
      "label": "Webhook Secret",
      "kind": "secret",
      "sensitive": true,
      "required": false,
      "default_mask": "whsec_\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022",
      "validation": { "regex": "^whsec_[A-Za-z0-9]{24,}$", "hint": "Webhook signing secret (X-Hub-Signature-256 HMAC-SHA256)" },
      "rotatable": true,
      "expires_at_supported": false,
      "group": "secondary",
      "description": "Webhook signing secret used to verify X-Hub-Signature-256."
    },
    {
      "key": "oauth_app_client_id",
      "label": "OAuth App Client ID",
      "kind": "text",
      "sensitive": false,
      "required": false,
      "placeholder": "Iv1.abc123...",
      "validation": { "regex": "^(Iv1|Iv2)\\.[A-Za-z0-9]{16,}$", "hint": "OAuth App client ID (Iv1./Iv2. prefix)" },
      "rotatable": false,
      "expires_at_supported": false,
      "group": "advanced",
      "description": "OAuth App client ID."
    },
    {
      "key": "oauth_app_client_secret",
      "label": "OAuth App Client Secret",
      "kind": "secret",
      "sensitive": true,
      "required": false,
      "default_mask": "\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022",
      "rotatable": true,
      "expires_at_supported": false,
      "group": "advanced",
      "description": "OAuth App client secret."
    },
    {
      "key": "backup_codes_2fa",
      "label": "2FA Backup Codes",
      "kind": "text",
      "sensitive": true,
      "required": false,
      "placeholder": "xxxxxxxxxx, xxxxxxxxxx, ...",
      "rotatable": false,
      "expires_at_supported": false,
      "group": "secondary",
      "description": "Comma-separated 2FA recovery codes. Store offline."
    }
  ]
}
