<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OmniKeyVault.Cli.Gui.Views.KeePassImportWindow"
        Title="从 KeePass 导入"
        Width="560" Height="380"
        MinWidth="480" MinHeight="320"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgElevatedBrush}">
    <Window.Styles>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AccentFgBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="14,8" />
        </Style>
        <Style Selector="Button.ghost">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource FgMutedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrightBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="14,8" />
        </Style>
        <Style Selector="TextBox.field">
            <Setter Property="Background" Value="{DynamicResource BgSunkenBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrightBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource FgBrush}" />
        </Style>
    </Window.Styles>

    <DockPanel>
        <Border DockPanel.Dock="Top" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="20,16">
            <StackPanel Spacing="4">
                <TextBlock Text="🔐 从 KeePass 导入"
                           FontFamily="{DynamicResource FontDisplay}" FontSize="17" FontWeight="Medium"
                           Foreground="{DynamicResource FgBrush}" />
                <TextBlock TextWrapping="Wrap" FontSize="11"
                           Foreground="{DynamicResource FgDimBrush}">
                    <Run Text="支持 KeePass 2.x XML 导出格式。在 KeePass 中: 文件 → 导出 → KeePass 2 XML" />
                    <Run Text="(JSON 与 Bitwarden 格式请用 Bitwarden 导入器)。" />
                </TextBlock>
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Bottom" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="20,12">
            <StackPanel Spacing="10">
                <TextBlock x:Name="StatusText" IsVisible="False" FontSize="11" TextWrapping="Wrap" />
                <Grid ColumnDefinitions="*,Auto,Auto">
                    <Button Grid.Column="1" Classes="ghost" Click="OnCloseClick" Margin="0,0,8,0">
                        <TextBlock Text="关闭" />
                    </Button>
                    <Button Grid.Column="2" x:Name="ImportButton" Classes="primary" Click="OnImportClick">
                        <TextBlock Text="导入到当前 Profile" />
                    </Button>
                </Grid>
            </StackPanel>
        </Border>

        <StackPanel Margin="20" Spacing="14">
            <StackPanel Spacing="4">
                <TextBlock Text="XML 文件路径"
                           FontFamily="{DynamicResource FontMono}" FontSize="10" LetterSpacing="1.2"
                           Foreground="{DynamicResource FgFaintBrush}" />
                <Grid ColumnDefinitions="*,Auto">
                    <TextBox Grid.Column="0" Classes="field" x:Name="PathBox"
                             Watermark="C:\Users\me\Desktop\keepass-export.xml" />
                    <Button Grid.Column="1" Classes="ghost" Padding="10,4" Margin="6,0,0,0" Click="OnBrowseClick">
                        <TextBlock Text="📂 浏览" FontSize="11" />
                    </Button>
                </Grid>
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="目标 Profile"
                           FontFamily="{DynamicResource FontMono}" FontSize="10" LetterSpacing="1.2"
                           Foreground="{DynamicResource FgFaintBrush}" />
                <TextBlock x:Name="TargetProfileText" FontFamily="{DynamicResource FontMono}" FontSize="12"
                           Foreground="{DynamicResource FgMutedBrush}" />
                <TextBlock Text="提示: 切到 dev / test Profile 导入可避免污染生产数据。"
                           FontSize="10" Foreground="{DynamicResource FgDimBrush}" />
            </StackPanel>

            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4"
                    Background="{DynamicResource BgSunkenBrush}" Padding="12">
                <StackPanel Spacing="6">
                    <TextBlock Text="导入策略" FontFamily="{DynamicResource FontMono}" FontSize="10" LetterSpacing="1.2"
                               Foreground="{DynamicResource FgFaintBrush}" />
                    <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{DynamicResource FgMutedBrush}">
                        <Run Text="• Title → 条目名称" />
                        <LineBreak />
                        <Run Text="• UserName / Password / URL → username / password / url 字段" />
                        <LineBreak />
                        <Run Text="• Notes → 备注" />
                        <LineBreak />
                        <Run Text="• 自定义属性 → 字段 (otp / totp 自动识别为 TOTP URI)" />
                        <LineBreak />
                        <Run Text="• URL host → 自动匹配 platform_id (openai / github / ...)" />
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>
    </DockPanel>
</Window>
